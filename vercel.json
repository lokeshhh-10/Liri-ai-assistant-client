{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/blog/:path*",
      "destination": "/api/seo"
    },
    {
      "source": "/:path((?!api|@|src|node_modules|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
